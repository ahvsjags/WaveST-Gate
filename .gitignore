# Python and local caches
__pycache__/
*.py[cod]
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Local environments and machine-specific files
.env
.env.*
.venv/
venv/
env/
.idea/
.vscode/
*.log

# Large raw/processed data and interrupted downloads
data/raw/
data/processed/
download_logs/
reports/

# Large binary/model artifacts
*.pt
*.pth
*.ckpt
*.h5ad
*.h5
*.loom
*.zarr/
*.tar
*.tar.gz
*.tgz
*.zip
*.gz
*.bin

# Large raster exports; editable vector exports are kept.
*.tif
*.tiff
*.ome.tif
*.ome.tiff
*.png
*.jpg
*.jpeg

# De-identified WaveST-MDT demo textures are required by the public workstation.
!wavest-mdt-app/public/assets/*.png
!wavest-mdt-app/dist/assets/*.png

# Keep the reproducibility/release evidence chain lightweight on GitHub.
!results/
results/*

!results/nature_release/
results/nature_release/*
!results/nature_release/*.json
!results/nature_release/*.md
!results/nature_release/*.csv
